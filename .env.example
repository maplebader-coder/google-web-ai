# Google AI Proxy 配置文件
# 复制此文件为 .env 并修改配置

# 服务配置
HOST=0.0.0.0
PORT=8787
DEBUG=false

# 管理后台
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# 数据库（默认SQLite，也支持PostgreSQL/MySQL）
DATABASE_URL=sqlite+aiosqlite:///data/proxy.db

# 账户轮询策略: round_robin / random / least_used
ACCOUNT_ROTATION_STRATEGY=round_robin

# Cookie 轮换间隔（秒）
COOKIE_ROTATE_INTERVAL=600

# 运行模式: login（登录Cookie模式） | anonymous（未登录模式） | auto（优先Cookie，无账户时降级匿名）
RUN_MODE=auto

# 请求超时（秒）
REQUEST_TIMEOUT=60

# 最大重试次数
MAX_RETRIES=2

# HTTP代理（可选，用于访问Google）
# HTTP_PROXY=http://127.0.0.1:7890

# API Key（逗号分隔，留空则不校验；也可通过管理后台创建）
# API_KEYS=sk-your-key-1,sk-your-key-2

# 日志
LOG_LEVEL=INFO
LOG_FILE=data/logs/app.log
